# kira doctor detects each violation class on a broken fixture and exits non-zero.
env GIT_CONFIG_GLOBAL=/dev/null
env GIT_CONFIG_SYSTEM=/dev/null
env EDITOR=true
exec git init
exec git config user.email test@example.com
exec git config user.name tester
exec kira init --key KIRA
exec kira create ticket --title 'real one' --no-edit
exec kira index

# a clean repo with a built index reports ok, a fresh index, and exits zero
exec kira doctor
stdout 'index is up to date'
stdout 'ok: 0 error'

# drop in broken items: schema/state/vocab/refs violations + a colliding number
cp broken.md .kira/tickets/01HZZZZZZZZZZZZZZZZZZZZZZZA.md
cp collider.md .kira/tickets/01HZZZZZZZZZZZZZZZZZZZZZZZB.md

! exec kira doctor
stdout 'error   state'
stdout 'dangling-ref'
stdout 'error   schema'
stdout 'vocab'
stdout 'id-collision'
stdout 'index is stale'
stdout 'problems found'

# --json emits a machine-readable report on stdout and still exits non-zero
! exec kira doctor --json
stdout '"ok": false'
stdout '"class": "id-collision"'
stdout '"kind": "live-live"'

-- broken.md --
---
id: 01HZZZZZZZZZZZZZZZZZZZZZZZA
number: KIRA-50
aliases: []
type: ticket
title: broken
state: NONEXISTENT
labels: [notaknownlabel]
blocked_by: [01HXXXXXXXXXXXXXXXXXXXXXXX]
epic: 01HYYYYYYYYYYYYYYYYYYYYYYY
due: not-a-date
sprint: 2099-S1
mystery_field: 1
created: 2026-07-10T09:14:00+05:30
updated: 2026-07-10T09:14:00+05:30
---
## Description

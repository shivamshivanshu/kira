# kira validate checks a single file against the schema and config; nvim/pre-commit plumbing.
env GIT_CONFIG_GLOBAL=/dev/null
env GIT_CONFIG_SYSTEM=/dev/null
env EDITOR=true
exec git init
exec git config user.email test@example.com
exec git config user.name tester
exec kira init --key KIRA
exec kira create ticket --title 'anchor' --no-edit

# a well-formed file passes and exits zero
cp good.md .kira/tickets/01HZZZZZZZZZZZZZZZZZZZZZZA.md
exec kira validate .kira/tickets/01HZZZZZZZZZZZZZZZZZZZZZZA.md
stdout 'ok: 0 error'

# a file with a bad state fails and reports only that file
! exec kira validate bad.md
stdout 'error   state'
stdout 'problems found'

# --json report on stdout, non-zero exit
! exec kira validate --json bad.md
stdout '"ok": false'

# a ticket number resolves to its file and validates
exec kira validate KIRA-90
stdout 'ok: 0 error'

# a ulid prefix resolves to the same file
exec kira validate 01HZZZZZZZZ
stdout 'ok: 0 error'

# an arg that is neither a file nor a resolvable id is rejected
! exec kira validate KIRA-99999
stderr 'neither a file nor a resolvable ticket id'

# the project config is not a ticket file; validate refuses with a clear pointer to doctor
! exec kira validate .kira/config.yaml
stderr 'is the project config, not a ticket file'
stderr 'kira doctor'

-- good.md --
---
id: 01HZZZZZZZZZZZZZZZZZZZZZZA
number: KIRA-90
aliases: []
type: ticket
title: fine
state: TODO
labels: [bug]
blocked_by: []
epic: null
created: 2026-07-10T09:14:00+05:30
updated: 2026-07-10T09:14:00+05:30
---
## Description
-- bad.md --
---
id: 01HZZZZZZZZZZZZZZZZZZZZZZC
number: KIRA-91
aliases: []
type: ticket
title: bad state
state: WAT
labels: []
blocked_by: []
epic: null
created: 2026-07-10T09:14:00+05:30
updated: 2026-07-10T09:14:00+05:30
---

# create mints sequential numbers and commits one per mutation under auto mode.
env GIT_CONFIG_GLOBAL=/dev/null
env GIT_CONFIG_SYSTEM=/dev/null
env EDITOR=true
exec git init
exec git config user.email test@example.com
exec git config user.name tester
exec kira init --key KIRA

# EDITOR=true leaves the flag-filled template unchanged, so the create is valid.
exec kira create ticket --title 'First ticket' --json
stdout '"number": "KIRA-1"'
stdout '"state": "TODO"'
exec git log --oneline
stdout 'kira: KIRA-1 create'

# the next create allocates KIRA-2
exec kira create ticket --title 'Second' --no-edit --json
stdout '"number": "KIRA-2"'

# exactly three commits: init + two creates (one structured commit per mutation)
exec git rev-list --count HEAD
stdout '^3$'

# show carries index-derived fields: the creation commit links back via its
# Kira-Ticket trailer, while a freshly created ticket has no history events yet
exec kira show KIRA-1 --json
stdout '"title": "First ticket"'
stdout '"blocks": \[\]'
stdout '"linked_commits":'
stdout 'kira: KIRA-1 create'
stdout '"history_tail": \[\]'

# create --json emits the shared item schema (category/owner/epic_number/priority), not just id/number/path
exec kira create epic --title 'Parent' --no-edit --json
stdout '"number": "KIRA-3"'
exec kira create ticket --title 'Child' --no-edit --parent KIRA-3 --json
stdout '"category": "todo"'
stdout '"epic_number": "KIRA-3"'
stdout '"priority": null'

# a positional title works in addition to --title
exec kira create ticket 'Positional title' --no-edit --json
stdout '"title": "Positional title"'

# positional title and --title together is an error
! exec kira create ticket 'X' --title 'Y' --no-edit
stderr 'not both'

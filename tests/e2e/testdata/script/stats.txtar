# stats --sprint / --velocity: burndown and velocity derived from the
# git-derived transition events (docs/design/08-telemetry.md §2, §4). Commit
# dates are pinned via GIT_COMMITTER_DATE so the event stream — and therefore
# the series — is fully deterministic; TZ is pinned because done-days are
# local-time day boundaries.
env TZ=UTC
env GIT_CONFIG_GLOBAL=/dev/null
env GIT_CONFIG_SYSTEM=/dev/null
env EDITOR=true
mkdir proj
cd proj
exec git init
exec git config user.email test@example.com
exec git config user.name tester
exec kira init --key KIRA
exec kira sprint create --key 2026-S1 --name 'Sprint 1' --start 2026-01-05 --end 2026-01-09
exec kira sprint create --key 2026-S2 --name 'Sprint 2' --start 2026-02-02 --end 2026-02-06

# sprint 1: 3+5+2+7 points estimated plus one unestimated item
env GIT_COMMITTER_DATE=2026-01-05T10:00:00+00:00
exec kira create ticket --title 'T1' --no-edit --sprint 2026-S1 --estimate 3
exec kira create ticket --title 'T2' --no-edit --sprint 2026-S1 --estimate 5
exec kira create ticket --title 'T3' --no-edit --sprint 2026-S1 --estimate 2
exec kira create ticket --title 'T4' --no-edit --sprint 2026-S1
exec kira create ticket --title 'T5' --no-edit --sprint 2026-S1 --estimate 7

# 7 points dropped on day two — done-category, so it stops burning, but
# velocity must exclude it
env GIT_COMMITTER_DATE=2026-01-06T10:00:00+00:00
exec kira move KIRA-1 IN_PROGRESS
exec kira move KIRA-2 IN_PROGRESS
exec kira move KIRA-5 WONT_DO --resolution dropped

# 3 points done on day three, 5 on day four; 2 points (T3) never finish
env GIT_COMMITTER_DATE=2026-01-07T10:00:00+00:00
exec kira move KIRA-1 REVIEW
exec kira move KIRA-1 DONE --resolution done
env GIT_COMMITTER_DATE=2026-01-08T10:00:00+00:00
exec kira move KIRA-2 REVIEW
exec kira move KIRA-2 DONE --resolution done

# sprint 2: 4 points done inside its window
env GIT_COMMITTER_DATE=2026-02-02T10:00:00+00:00
exec kira create ticket --title 'U1' --no-edit --sprint 2026-S2 --estimate 4
exec kira move KIRA-6 IN_PROGRESS
env GIT_COMMITTER_DATE=2026-02-03T10:00:00+00:00
exec kira move KIRA-6 REVIEW
exec kira move KIRA-6 DONE --resolution done

# burndown: remaining 17 -> 10 -> 7 -> 2 -> 2, ideal 17 -> 0 in quarters
exec kira stats --sprint 2026-S1 --json
stdout '"sprint": "2026-S1"'
stdout '"unit": "points"'
stdout '"date": "2026-01-05",\n\s*"remaining": 17,\n\s*"ideal": 17'
stdout '"date": "2026-01-06",\n\s*"remaining": 10,\n\s*"ideal": 12.8'
stdout '"date": "2026-01-07",\n\s*"remaining": 7,\n\s*"ideal": 8.5'
stdout '"date": "2026-01-08",\n\s*"remaining": 2,\n\s*"ideal": 4.3'
stdout '"date": "2026-01-09",\n\s*"remaining": 2,\n\s*"ideal": 0'
stdout '"unestimated": 1'
stdout '"degraded_n": 0'

# velocity: dropped points excluded, sprints listed end-ascending
exec kira stats --velocity --json
stdout '"key": "2026-S1",\n\s*"completed": 8'
stdout '"key": "2026-S2",\n\s*"completed": 4'
stdout '"trailing_3": 6'

# both blocks together, --sprint resolving 'active' via the pointer
exec kira sprint activate 2026-S1
exec kira stats --sprint active --velocity --json
stdout '"sprint": "2026-S1"'
stdout '"trailing_3": 6'

# the human render carries the same numbers
exec kira stats --sprint 2026-S1
stdout 'Burndown 2026-S1'
stdout '2026-01-06  remaining 10  ideal 12.8'
stdout 'unestimated items \(burn nothing\): 1'

# bare stats: project-wide general metrics (docs/design/08-telemetry.md §2).
# done = KIRA-1,2,6 (done-category, not dropped); KIRA-5 dropped; total 6.
# cycle time is derived from commit dates (KIRA-1 1d, KIRA-2 2d, KIRA-6 1d).
exec kira stats --json
stdout '"total": 6'
stdout '"done": 3'
stdout '"dropped": 1'
stdout '"pct": 0.5'
stdout '"cycle_time_days"'
stdout '"lead_time_days"'
stdout '"throughput_per_week"'
stdout '"estimate"'

# the human render carries completion
exec kira stats
stdout 'completion: 3/6 done \(50%\)'

# unknown sprint and unset active pointer are user errors
! exec kira stats --sprint 2099-S1
stderr 'not a key in the configured sprints'
exec kira sprint close 2026-S1
! exec kira stats --sprint active
stderr 'no active sprint is set'

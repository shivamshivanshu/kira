# board renders columns from the ticket workflow; --plain is a static, non-interactive table.
env GIT_CONFIG_GLOBAL=/dev/null
env GIT_CONFIG_SYSTEM=/dev/null
env EDITOR=true
# stdout is not a TTY under testscript, so the plain board honors COLUMNS then falls back to 80.
env COLUMNS=100
exec git init
exec git config user.email test@example.com
exec git config user.name tester
exec kira init --key KIRA

# an empty board teaches the configured column names
exec kira board --plain
stdout 'Columns:'
stdout 'TODO'
stdout 'WONT_DO'

# a created + moved ticket lands in its column
exec kira create ticket --title 'Burst regression' --no-edit
exec kira move KIRA-1 IN_PROGRESS
exec kira board --plain
stdout 'IN_PROGRESS'
stdout 'KIRA-1'

# the WIP header shows n/wip whenever a wip limit is configured (IN_PROGRESS wip=3)
stdout '1/3'

# a second ticket, created after the move
exec kira create ticket --title 'Later arrival' --no-edit

# --json emits the documented columns contract
exec kira board --json
stdout '"state": "TODO"'
stdout '"category": "todo"'
stdout '"state": "IN_PROGRESS"'

# --at renders a static board as of an older ref through the tree-ish loader:
# HEAD~2 predates both the move and KIRA-2
exec kira board --plain --at HEAD~2
stdout 'KIRA-1'
! stdout 'KIRA-2'

# the live board sees the later ticket
exec kira board --plain
stdout 'KIRA-2'

# a narrow width budget truncates long titles with an ellipsis instead of wrapping
env COLUMNS=40
exec kira create ticket --title 'A very long ticket title that will not fit' --no-edit
exec kira board --plain
stdout '…'
! stdout 'will not fit'
